rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to get user data from top-level /users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper to check user roles
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isJudge() {
      return isAuthenticated() && getUserData().role == 'judge';
    }

    function isTeamLeader() {
      return isAuthenticated() && getUserData().role == 'teamLeader';
    }

    // Helper functions for Student Registration settings
    function getFestival(festId) {
      return get(/databases/$(database)/documents/festivals/$(festId)).data;
    }

    function getRegMode(festId) {
      return getFestival(festId).get('studentRegistrationMode', 'adminOnly');
    }

    function isRegOpen(festId) {
      return getFestival(festId).get('studentRegistrationOpen', false);
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow admin to write anything. Allow users to update their own profile, but prevent modifying critical fields (role, teamId, active, permissions).
      allow write: if isAdmin() || (
        isAuthenticated() && 
        request.auth.uid == userId && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions', 'teamId', 'active'])
      );
    }

    // --- User Invitations Collection (Top-Level) ---
    match /userInvitations/{tokenHash} {
      // Anyone can read a token to verify it during activation
      allow read: if true;
      // Admins can create invitations
      allow create: if isAdmin();
      // Allow updating a pending token to 'used' during activation
      allow update: if isAdmin() || (
        resource.data.status == 'pending' && 
        request.resource.data.status == 'used' && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'activatedAt', 'activatedUid'])
      );
      // Only admins can delete invitations
      allow delete: if isAdmin();
    }

    // --- Master Students Collection ---
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- Global App Settings ---
    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Festivals Collection ---
    match /festivals/{festId} {
      allow read: if true;
      allow write: if isAdmin();

      // --- Divisions Subcollection ---
      match /divisions/{divId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Subdivisions Subcollection ---
      match /subdivisions/{subId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Categories Subcollection ---
      match /categories/{catId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Teams Subcollection ---
      match /teams/{teamId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Festival Students Subcollection ---
      match /festStudents/{festStudentId} {
        allow read: if isAdmin() || (
          isTeamLeader() && 
          getUserData().teamId != null && 
          resource.data.teamId == getUserData().teamId
        );

        allow create: if (
          // Admin Only mode creation by Admin
          (isAdmin() && getRegMode(festId) == 'adminOnly' && isRegOpen(festId) == true)
        ) || (
          // Team Leader Only mode creation by Team Leader
          (isTeamLeader() && getUserData().teamId != null && 
           getRegMode(festId) == 'teamLeadersOnly' && isRegOpen(festId) == true &&
           request.resource.data.teamId == getUserData().teamId)
        );

        allow update: if (
          // Admin updates in Admin Only mode, or emergency corrections and approvals in Team Leader mode
          (isAdmin() && (
            getRegMode(festId) == 'adminOnly' || 
            getRegMode(festId) == 'teamLeadersOnly'
          ))
        ) || (
          // Team Leader Updates
          isTeamLeader() && 
          getUserData().teamId != null && 
          getRegMode(festId) == 'teamLeadersOnly' && 
          isRegOpen(festId) == true &&
          resource.data.teamId == getUserData().teamId &&
          request.resource.data.teamId == getUserData().teamId &&
          // Prevent editing critical non-permitted fields
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'teamId', 'festId', 'createdBy', 'createdByRole', 'registrationSource', 
            'approvedBy', 'approvedAt', 'rejectedBy', 'rejectedAt'
          ]) &&
          // Cannot set status to active if approval is required (unless approval required is false)
          (
            request.resource.data.status != 'active' || 
            getFestival(festId).get('teamLeaderStudentApprovalRequired', false) == false
          )
        );

        allow delete: if isAdmin();
      }

      // --- Competitions Subcollection ---
      match /competitions/{compId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Entries Subcollection ---
      match /entries/{entryId} {
        allow read: if isAuthenticated();
        // Admins can write. Team Leaders can only submit or edit entries belonging to their team.
        allow write: if isAdmin() || (
          isTeamLeader() && 
          getUserData().teamId != null && 
          request.resource.data.teamId == getUserData().teamId
        );
      }

      // --- Judge Assignments Subcollection ---
      match /judgeAssignments/{assignId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }

      // --- Judge Marks Subcollection ---
      match /judgeMarks/{markId} {
        // Admins can read. Judges can only read their own submitted marks.
        allow read: if isAdmin() || (
          isJudge() && 
          resource.data.judgeUserId == request.auth.uid
        );
        allow write: if isAdmin() || (
          isJudge() && 
          request.resource.data.judgeUserId == request.auth.uid && 
          (resource == null || resource.data.submissionStatus == 'draft' || resource.data.submissionStatus == 'reopened' || resource.data.submissionStatus == 'correction_required' || resource.data.submissionStatus == 'resubmitted')
        );
      }

      // --- Stages Subcollection ---
      match /stages/{stageId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Schedules Subcollection ---
      match /schedules/{schedId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Grade Rules Subcollection ---
      match /gradeRules/{ruleId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Point Rules Subcollection ---
      match /pointRules/{ruleId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Penalties Subcollection ---
      match /penalties/{penId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }

      // --- Bonus Points Subcollection ---
      match /bonusPoints/{bonId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }

      // --- Results Subcollection ---
      match /results/{resId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }

      // --- Team Totals Subcollection ---
      match /teamTotals/{teamId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Certificates Subcollection ---
      match /certificates/{certId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Verification Documents Subcollection ---
      match /verificationDocs/{docId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Announcements Subcollection ---
      match /announcements/{annId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // --- Correction Requests Subcollection ---
      match /correctionRequests/{reqId} {
        allow read: if isAuthenticated();
        // Admins can write. Team Leaders can only submit or edit correction requests belonging to their team.
        allow write: if isAdmin() || (
          isTeamLeader() && 
          getUserData().teamId != null && 
          request.resource.data.teamId == getUserData().teamId
        );
      }

      // --- Audit Logs Subcollection ---
      match /auditLogs/{logId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
      }

      // --- Public Data Subcollection ---
      match /publicData/{pubId} {
        allow read: if true;
        allow write: if isAdmin();
        
        match /{document=**} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }
  }
}
