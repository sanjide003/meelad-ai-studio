rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to get user data from top-level /users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper to check user roles
    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'superAdmin';
    }

    function isAdmin() {
      return isAuthenticated() && (getUserData().role == 'admin' || getUserData().role == 'institutionAdmin' || getUserData().role == 'superAdmin');
    }

    function isInstitutionMember(institutionId) {
      return isSuperAdmin() || (isAuthenticated() && getUserData().institutionId == institutionId);
    }

    function isJudge() {
      return isAuthenticated() && getUserData().role == 'judge';
    }

    function isTeamLeader() {
      return isAuthenticated() && getUserData().role == 'teamLeader';
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow admin to write anything. Allow users to update their own profile, but prevent modifying critical fields (role, teamId, active, permissions).
      allow write: if isAdmin() || (
        isAuthenticated() && 
        request.auth.uid == userId && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions', 'teamId', 'active'])
      );
    }

    // --- User Invitations Collection (Top-Level) ---
    match /userInvitations/{tokenHash} {
      // Anyone can read a token to verify it during activation
      allow read: if true;
      // Admins can create invitations
      allow create: if isAdmin();
      // Allow updating a pending token to 'used' during activation
      allow update: if isAdmin() || (
        resource.data.status == 'pending' && 
        request.resource.data.status == 'used' && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'activatedAt', 'activatedUid'])
      );
      // Only admins can delete invitations
      allow delete: if isAdmin();
    }

    // --- Master Students Collection ---
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- Global App Settings ---
    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }


    // --- Public manual login index for institution admins (replace with Cloud Function + hashed passwords before launch). ---
    match /institutionLogins/{loginId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // --- Premium SaaS Institutions Collection ---
    match /institutions/{institutionId} {
      allow read: if isSuperAdmin() || isInstitutionMember(institutionId);
      allow create, update, delete: if isSuperAdmin();

      match /admins/{adminId} {
        allow read: if isSuperAdmin() || isInstitutionMember(institutionId);
        allow write: if isSuperAdmin();
      }

      match /festivals/{festId} {
        allow read: if isSuperAdmin() || isInstitutionMember(institutionId) || resource.data.publicRead == true;
        allow write: if isSuperAdmin() || isInstitutionMember(institutionId);

        match /manualUsers/{manualUserId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isInstitutionMember(institutionId);
        }

        match /publicData/{pubId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isInstitutionMember(institutionId);
          match /{document=**} {
            allow read: if true;
            allow write: if isSuperAdmin() || isInstitutionMember(institutionId);
          }
        }

        match /{document=**} {
          allow read: if isSuperAdmin() || isInstitutionMember(institutionId);
          allow write: if isSuperAdmin() || isInstitutionMember(institutionId);
        }
      }
    }


    // --- Legacy top-level festival paths are disabled for SaaS isolation. ---
    match /festivals/{document=**} {
      allow read, write: if false;
    }
  }
}
