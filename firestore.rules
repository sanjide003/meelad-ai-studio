rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to get user data from top-level /users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper to check user roles
    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'superAdmin';
    }

    function isAdmin() {
      return isAuthenticated() && (getUserData().role == 'admin' || getUserData().role == 'institutionAdmin' || getUserData().role == 'superAdmin');
    }

    function isInstitutionMember(institutionId) {
      return isSuperAdmin() || (isAuthenticated() && getUserData().active == true && getUserData().institutionId == institutionId);
    }

    function isValidManualSessionProfile(userId) {
      return isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.data.manualAuth == true &&
        request.resource.data.active == true &&
        request.resource.data.institutionId is string &&
        request.resource.data.festivalId is string &&
        request.resource.data.usernameLower is string &&
        request.resource.data.role in ['institutionAdmin', 'admin', 'judge', 'teamLeader'];
    }

    function isJudge() {
      return isAuthenticated() && getUserData().role == 'judge';
    }

    function isTeamLeader() {
      return isAuthenticated() && getUserData().role == 'teamLeader';
    }

    function isSameInstitutionResource() {
      return isAuthenticated() && resource.data.institutionId is string && getUserData().institutionId == resource.data.institutionId;
    }

    function isSameInstitutionCreate() {
      return isAuthenticated() && request.resource.data.institutionId is string && getUserData().institutionId == request.resource.data.institutionId;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin() || isSameInstitutionResource());
      allow list: if isAuthenticated() && (isSuperAdmin() || isSameInstitutionResource());
      // Super Admin/admin writes normal profiles. Manual institution credentials create an anonymous Firebase session profile
      // after the password is verified through institutionLogins, so scoped Firestore rules can enforce tenant isolation.
      allow create: if (isAdmin() && (isSuperAdmin() || isSameInstitutionCreate())) || isValidManualSessionProfile(userId);
      allow update: if (isAdmin() && (isSuperAdmin() || isSameInstitutionResource())) || (
        isAuthenticated() &&
        request.auth.uid == userId &&
        resource.data.manualAuth == true &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoginAt', 'updatedAt'])
      ) || (
        isAuthenticated() &&
        request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions', 'teamId', 'active', 'institutionId', 'festivalId', 'manualAuth'])
      );
      allow delete: if isAdmin() && (isSuperAdmin() || isSameInstitutionResource());
    }

    // --- User Invitations Collection (Top-Level) ---
    match /userInvitations/{tokenHash} {
      // Anyone can get a token to verify it during activation, but list queries stay institution-scoped.
      allow get: if true;
      allow list: if isAdmin() && (isSuperAdmin() || isSameInstitutionResource());
      // Admins can create invitations only for their own institution.
      allow create: if isAdmin() && (isSuperAdmin() || isSameInstitutionCreate());
      // Allow updating a pending token to 'used' during activation
      allow update: if (isAdmin() && (isSuperAdmin() || isSameInstitutionResource())) || (
        resource.data.status == 'pending' && 
        request.resource.data.status == 'used' && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'activatedAt', 'activatedUid'])
      );
      // Only admins can delete invitations
      allow delete: if isAdmin() && (isSuperAdmin() || isSameInstitutionResource());
    }

    // --- Master Students Collection ---
    match /students/{studentId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isSameInstitutionResource());
      allow write: if isAdmin() && (isSuperAdmin() || isSameInstitutionCreate() || isSameInstitutionResource());
    }

    // --- Global App Settings ---
    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }


    // --- Public manual login index for institution admins (replace with Cloud Function + hashed passwords before launch). ---
    match /institutionLogins/{loginId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // --- Premium SaaS Institutions Collection ---
    match /institutions/{institutionId} {
      allow read: if isSuperAdmin() || isInstitutionMember(institutionId);
      allow create, update, delete: if isSuperAdmin();

      match /admins/{adminId} {
        allow read: if isSuperAdmin() || isInstitutionMember(institutionId);
        allow write: if isSuperAdmin();
      }

      match /festivals/{festId} {
        allow read: if isSuperAdmin() || isInstitutionMember(institutionId) || resource.data.publicRead == true;
        allow write: if isSuperAdmin() || isInstitutionMember(institutionId);

        match /manualUsers/{manualUserId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isInstitutionMember(institutionId);
        }

        match /publicData/{pubId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isInstitutionMember(institutionId);
          match /{document=**} {
            allow read: if true;
            allow write: if isSuperAdmin() || isInstitutionMember(institutionId);
          }
        }

        match /{document=**} {
          allow read: if isSuperAdmin() || isInstitutionMember(institutionId);
          allow write: if isSuperAdmin() || isInstitutionMember(institutionId);
        }
      }
    }


    // --- Legacy top-level festival paths are disabled for SaaS isolation. ---
    match /festivals/{document=**} {
      allow read, write: if false;
    }
  }
}
