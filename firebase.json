{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "src/**",
      "my old project/**",
      "package.json",
      "package-lock.json",
      "tsconfig.json",
      "vite.config.ts",
      "README.md",
      "CHANGELOG.md",
      "DEPLOYMENT_STATUS.md",
      "FINAL_HANDOVER.md",
      "FINAL_TEST_REPORT.md",
      "KNOWN_LIMITATIONS.md",
      "metadata.json",
      "firebase-applet-config.json",
      "firebase-blueprint.json"
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}
